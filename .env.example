# Slack (required)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
APPROVER_SLACK_ID=U04UTG30V9A

# Google Gemini AI (free tier — get key at https://aistudio.google.com/apikey)
# Free limits: 1,500 requests/day, 15 req/min — more than enough for a Slack bot
GEMINI_API_KEY=

# Redis (required — persistent approvals, thread memory, dedup, learning store)
REDIS_URL=redis://localhost:6379/0

# Escalation chain — ping backup approver if action not approved in N minutes
ESCALATION_APPROVER_ID=          # Slack user ID of backup approver
ESCALATION_WAIT_MINUTES=15       # minutes before first DM ping
MOBILE_INFRA_SLACK_ID=           # Slack user/group ID tagged for GH Actions approvals + lifecycle notifications

# SSH / Bastion
BASTION_HOST=
BASTION_USER=
BASTION_KEY_PATH=

# Jenkins
JENKINS_URL=
JENKINS_USER=
JENKINS_API_TOKEN=

# GitHub
GITHUB_TOKEN=

# Database (MySQL)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

# Jira
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_CLOUD_ID=3def4f78-101d-4614-9b65-735c17a98a93
JIRA_ASSIGNEE_ID=642196d2b05b4e3e7dab5355

# Token expiry dates (YYYY-MM-DD) — shown in Home Tab dashboard as warnings
JIRA_TOKEN_EXPIRES=
JENKINS_TOKEN_EXPIRES=
